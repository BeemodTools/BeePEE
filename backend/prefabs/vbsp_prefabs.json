{
    "categories": [
        {
            "name": "Connection State",
            "description": "Conditions based on input connections (like stairs/panels)",
            "prefabs": [
                {
                    "id": "if_no_input_change_instance",
                    "name": "Static When Unconnected",
                    "description": "Change to a static instance when item has no input connections (like stairs become solid tiles)",
                    "blocks": [
                        {
                            "type": "if",
                            "displayName": "If No Connections",
                            "variable": "$connectioncount",
                            "operator": "==",
                            "value": "0",
                            "thenBlocks": [
                                {
                                    "type": "changeInstance",
                                    "displayName": "Static Instance",
                                    "instanceName": ""
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "if_has_input_change_instance",
                    "name": "Active When Connected",
                    "description": "Change to an active instance when item has input connections",
                    "blocks": [
                        {
                            "type": "if",
                            "displayName": "If Has Connections",
                            "variable": "$connectioncount",
                            "operator": ">",
                            "value": "0",
                            "thenBlocks": [
                                {
                                    "type": "changeInstance",
                                    "displayName": "Active Instance",
                                    "instanceName": ""
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "if_else_connection_state",
                    "name": "Connected vs Unconnected",
                    "description": "Use different instances based on connection state (if connected / else unconnected)",
                    "blocks": [
                        {
                            "type": "ifElse",
                            "displayName": "Connection Check",
                            "variable": "$connectioncount",
                            "operator": "==",
                            "value": "0",
                            "thenBlocks": [
                                {
                                    "type": "changeInstance",
                                    "displayName": "Unconnected Instance",
                                    "instanceName": ""
                                }
                            ],
                            "elseBlocks": [
                                {
                                    "type": "changeInstance",
                                    "displayName": "Connected Instance",
                                    "instanceName": ""
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "if_has_input_set_var",
                    "name": "Set Variable When Connected",
                    "description": "Set a fixup variable when item has input connections",
                    "blocks": [
                        {
                            "type": "if",
                            "displayName": "If Has Connections",
                            "variable": "$connectioncount",
                            "operator": ">",
                            "value": "0",
                            "thenBlocks": [
                                {
                                    "type": "setInstVar",
                                    "displayName": "Set Variable",
                                    "variable": "$enabled",
                                    "value": "1"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "name": "Switches",
            "description": "Switch statements for multi-value variables",
            "prefabs": [
                {
                    "id": "switch_cube_type",
                    "name": "Cube Type",
                    "description": "Switch for all cube types (Standard, Companion, Reflection, Sphere, FrankenTurret)",
                    "blocks": [
                        {
                            "type": "switchCase",
                            "displayName": "Cube Type",
                            "variable": "$cube_type",
                            "cases": [
                                {
                                    "type": "case",
                                    "displayName": "Standard",
                                    "value": "0",
                                    "thenBlocks": [
                                        {
                                            "type": "changeInstance",
                                            "displayName": "Standard Cube",
                                            "instanceName": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "case",
                                    "displayName": "Companion",
                                    "value": "1",
                                    "thenBlocks": [
                                        {
                                            "type": "changeInstance",
                                            "displayName": "Companion Cube",
                                            "instanceName": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "case",
                                    "displayName": "Reflection",
                                    "value": "2",
                                    "thenBlocks": [
                                        {
                                            "type": "changeInstance",
                                            "displayName": "Reflection Cube",
                                            "instanceName": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "case",
                                    "displayName": "Sphere",
                                    "value": "3",
                                    "thenBlocks": [
                                        {
                                            "type": "changeInstance",
                                            "displayName": "Sphere Cube",
                                            "instanceName": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "case",
                                    "displayName": "FrankenTurret",
                                    "value": "4",
                                    "thenBlocks": [
                                        {
                                            "type": "changeInstance",
                                            "displayName": "FrankenTurret",
                                            "instanceName": ""
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "switch_timer_delay",
                    "name": "Timer Delay",
                    "description": "Switch for timer delay values (0-3 seconds)",
                    "blocks": [
                        {
                            "type": "switchCase",
                            "displayName": "Timer Delay",
                            "variable": "$timer_delay",
                            "cases": [
                                {
                                    "type": "case",
                                    "displayName": "0 seconds",
                                    "value": "0",
                                    "thenBlocks": []
                                },
                                {
                                    "type": "case",
                                    "displayName": "1 second",
                                    "value": "1",
                                    "thenBlocks": []
                                },
                                {
                                    "type": "case",
                                    "displayName": "2 seconds",
                                    "value": "2",
                                    "thenBlocks": []
                                },
                                {
                                    "type": "case",
                                    "displayName": "3 seconds",
                                    "value": "3",
                                    "thenBlocks": []
                                },
                                {
                                    "type": "case",
                                    "displayName": "Default",
                                    "value": "",
                                    "thenBlocks": []
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "name": "Booleans",
            "description": "If/Else conditions for true/false values",
            "prefabs": [
                {
                    "id": "bool_general",
                    "name": "General If",
                    "description": "Generic if/else condition - set your own variable",
                    "blocks": [
                        {
                            "type": "ifElse",
                            "displayName": "If Condition",
                            "variable": "$variable",
                            "operator": "==",
                            "value": "1",
                            "thenBlocks": [
                                {
                                    "type": "changeInstance",
                                    "displayName": "True Instance",
                                    "instanceName": ""
                                }
                            ],
                            "elseBlocks": [
                                {
                                    "type": "changeInstance",
                                    "displayName": "False Instance",
                                    "instanceName": ""
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
